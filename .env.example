# QuantumPass Environment Variables
# Copy this file to .env and fill in your actual values

# LLM Backend - NVIDIA NIM (Primary for HexAgent governance)
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here

# LLM Backend - Groq (Kraft-01 agent)
GROQ_API_KEY=your_groq_api_key_here

# Zenodo Integration (for bead minting)
ZENODO_TOKEN=your_zenodo_access_token_here
ZENODO_USE_SANDBOX=true

# Optional: Mistral API
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional: OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Vercel Deployment (if deploying)
VERCEL_TOKEN=your_vercel_token_here
